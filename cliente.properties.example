# SIGOMEI - Configuracion del cliente para conectar al servidor por RMI
#
# Copia este archivo a cliente.properties (en la raiz del proyecto) y ajusta
# los valores. cliente.properties esta ignorado por git para que cada dev
# tenga su propia configuracion.
#
# Alternativamente, puedes sobrescribir cualquier valor con variables de
# entorno (tienen prioridad sobre cliente.properties):
#   SIGOMEI_RMI_HOST
#   SIGOMEI_RMI_PORT

rmi.host=localhost
rmi.port=1099
