<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sigomei.cliente.vista.EquiposTabController">

    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Equipos" styleClass="title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refrescar" onAction="#onRefrescar"/>
        <Button text="Editar" onAction="#onEditar"/>
        <Button text="Desactivar" onAction="#onDesactivar" styleClass="button,button-danger"/>
        <Button text="+ Nuevo equipo" onAction="#onNuevo" styleClass="button,button-primary"/>
    </HBox>

    <VBox styleClass="card" VBox.vgrow="ALWAYS">
        <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"          text="ID"           prefWidth="60"/>
                <TableColumn fx:id="colNombre"      text="NOMBRE"       prefWidth="220"/>
                <TableColumn fx:id="colTipo"        text="TIPO"         prefWidth="130"/>
                <TableColumn fx:id="colSerie"       text="N° SERIE"     prefWidth="120"/>
                <TableColumn fx:id="colCriticidad"  text="CRITICIDAD"   prefWidth="110"/>
                <TableColumn fx:id="colEstado"      text="ESTADO"       prefWidth="150"/>
                <TableColumn fx:id="colMarca"       text="MARCA"        prefWidth="110"/>
                <TableColumn fx:id="colModelo"      text="MODELO"       prefWidth="110"/>
                <TableColumn fx:id="colUbicacion"   text="UBICACIÓN"    prefWidth="150"/>
            </columns>
        </TableView>
    </VBox>

    <Label fx:id="lblMensaje" styleClass="status-message"/>
</VBox>
