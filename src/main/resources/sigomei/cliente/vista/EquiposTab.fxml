<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sigomei.cliente.vista.EquiposTabController">

    <!-- Barra de filtros -->
    <HBox styleClass="filter-bar" spacing="12" alignment="CENTER_LEFT">
        <VBox spacing="2">
            <Label text="Tipo"/>
            <ComboBox fx:id="filtroTipo" styleClass="filter-combo" prefWidth="120" promptText="Todos"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Criticidad"/>
            <ComboBox fx:id="filtroCriticidad" styleClass="filter-combo" prefWidth="120" promptText="Todas"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Estado"/>
            <ComboBox fx:id="filtroEstado" styleClass="filter-combo" prefWidth="120" promptText="Todos"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Búsqueda"/>
            <TextField fx:id="filtroBusqueda" styleClass="filter-field" prefWidth="200"
                       promptText="nombre, N° de serie, ID..."/>
        </VBox>
        <Region HBox.hgrow="SOMETIMES" minWidth="8"/>
        <Button text="Buscar" onAction="#onBuscar" styleClass="button,button-primary"/>
        <Button text="Limpiar" onAction="#onLimpiar"/>
        <Button text="Refrescar" onAction="#onRefrescar"/>
    </HBox>

    <!-- Contenido principal -->
    <SplitPane fx:id="splitPane" VBox.vgrow="ALWAYS" dividerPositions="0.65">

        <!-- Lado izquierdo: tabla + paginación + nuevo -->
        <VBox spacing="0">
            <padding><Insets top="0" right="0" bottom="12" left="0"/></padding>

            <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId"          text="ID"           prefWidth="60"/>
                    <TableColumn fx:id="colNombre"      text="NOMBRE"       prefWidth="160"/>
                    <TableColumn fx:id="colTipo"        text="TIPO"         prefWidth="120"/>
                    <TableColumn fx:id="colSerie"       text="N° SERIE"     prefWidth="120"/>
                    <TableColumn fx:id="colCriticidad"  text="CRITICIDAD"   prefWidth="90"/>
                    <TableColumn fx:id="colEstado"      text="ESTADO"       prefWidth="130"/>
                    <TableColumn fx:id="colAcciones"    text="ACCIONES"     prefWidth="160" sortable="false"/>
                </columns>
            </TableView>

            <!-- Pie: nuevo + paginación -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <padding><Insets top="8" right="16" bottom="0" left="16"/></padding>
                <Button text="+ Nuevo Equipo" onAction="#onNuevo" styleClass="button,button-primary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox fx:id="paginacionBox" styleClass="pagination-bar"/>
            </HBox>
        </VBox>

        <!-- Lado derecho: formulario embebido (se muestra/oculta) -->
        <VBox fx:id="panelLateral" styleClass="side-panel" visible="false" managed="false">
            <fx:include fx:id="formularioEquipo" source="FormularioEquipo.fxml"/>
        </VBox>
    </SplitPane>

    <Label fx:id="lblMensaje" styleClass="status-message">
        <padding><Insets left="16"/></padding>
    </Label>
</VBox>

