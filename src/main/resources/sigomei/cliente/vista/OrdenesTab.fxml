<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="sigomei.cliente.vista.OrdenesTabController">

    <!-- Barra de filtros -->
    <HBox styleClass="filter-bar" spacing="12" alignment="CENTER_LEFT">
        <VBox spacing="2">
            <Label text="Estado"/>
            <ComboBox fx:id="filtroEstado" styleClass="filter-combo" prefWidth="130" promptText="Todos"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Equipo"/>
            <ComboBox fx:id="filtroEquipo" styleClass="filter-combo" prefWidth="160" promptText="Seleccionar..."/>
        </VBox>
        <VBox spacing="2">
            <Label text="Técnico"/>
            <ComboBox fx:id="filtroTecnico" styleClass="filter-combo" prefWidth="140" promptText="Cualquiera"/>
        </VBox>
        <VBox spacing="2">
            <Label text="Fecha programada"/>
            <DatePicker fx:id="filtroFecha" styleClass="filter-combo" prefWidth="150" promptText="dd/mm/aaaa"/>
        </VBox>
        <Region HBox.hgrow="SOMETIMES" minWidth="8"/>
        <Button text="Buscar" onAction="#onBuscar" styleClass="button,button-primary"/>
        <Button text="Limpiar" onAction="#onLimpiar"/>
        <Button text="Refrescar" onAction="#onRefrescar"/>
    </HBox>

    <!-- Tabla de órdenes -->
    <VBox VBox.vgrow="ALWAYS" spacing="0">
        <padding><Insets top="0" right="0" bottom="12" left="0"/></padding>

        <TableView fx:id="tabla" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"        text="ID"           prefWidth="70"/>
                <TableColumn fx:id="colEquipo"    text="EQUIPO"       prefWidth="160"/>
                <TableColumn fx:id="colTecnico"   text="TÉCNICO"      prefWidth="140"/>
                <TableColumn fx:id="colTipo"      text="TIPO"         prefWidth="100"/>
                <TableColumn fx:id="colFechaProg" text="FECHA PROG."  prefWidth="110"/>
                <TableColumn fx:id="colEstado"    text="ESTADO"       prefWidth="120"/>
                <TableColumn fx:id="colAcciones"  text="ACCIONES"     prefWidth="280" sortable="false"/>
            </columns>
        </TableView>

        <!-- Pie: nueva orden + paginación -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="8" right="16" bottom="0" left="16"/></padding>
            <Button text="+ Nueva Orden" onAction="#onNueva" styleClass="button,button-primary"/>
            <Region HBox.hgrow="ALWAYS"/>
            <HBox fx:id="paginacionBox" styleClass="pagination-bar"/>
        </HBox>
    </VBox>

    <Label fx:id="lblMensaje" styleClass="status-message">
        <padding><Insets left="16"/></padding>
    </Label>
</VBox>
